# Copy to .env in this directory for local runs (see .gitignore — .env is not committed).
# Local Zeebe (Docker Compose): plaintext gRPC on port 26500
ZEEBE_ADDRESS=127.0.0.1:26500

# Set true explicitly for local plaintext; omit or false when using Camunda Cloud OAuth
ZEEBE_LOCAL_PLAINTEXT=true

# Optional: comma-separated job types (default: both tutorial types)
# JOB_TYPES=c8jw-golang,c8jw-python

# Camunda Cloud (uncomment and fill — then set ZEEBE_LOCAL_PLAINTEXT=false or unset)
# ZEEBE_CLIENT_ID=
# ZEEBE_CLIENT_SECRET=
# ZEEBE_ADDRESS=your-cluster.grpc.cloud.camunda.io:443
# ZEEBE_AUTHORIZATION_SERVER_URL=https://login.cloud.camunda.io/oauth/token/
